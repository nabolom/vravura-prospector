# Token gratuito de la API oficial DENUE. Configurarlo como secreto del servidor.
DENUE_TOKEN=

# Acceso temporal por usuario y contraseña. Configurar únicamente como secretos del hosting.
APP_LOGIN_EMAIL=
APP_LOGIN_PASSWORD=
# Generar con: openssl rand -base64 48
AUTH_COOKIE_SECRET=

# Sincronización server-side con el diagnóstico ARL. No reutilizar estas claves para el login.
ARL_SUPABASE_URL=
ARL_SUPABASE_ANON_KEY=

# Login independiente por magic link (proyecto Supabase Auth separado recomendado).
AUTH_SUPABASE_URL=
AUTH_SUPABASE_ANON_KEY=
AUTH_ALLOWED_EMAILS=leon.ruiz17@gmail.com,milo@vravura.com
APP_URL=
